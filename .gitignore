# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# --- GNU Octave ---
*.oct               # compiled C++ oct-files
*.mex*              # compiled MEX files (.mex, .mexa64, .mexw64, .mexmaci64, etc.)
*.mat               # binary Octave/MATLAB data files (often huge; comment out if you want to track them)
*.fig               # MATLAB/Octave figure files
octave-workspace    # saved workspace when you run `save`
octave-core*        # core dump if Octave crashes
.octave_hist        # command history
*~                  # backup files from editors (e.g. script.m~)
*.asv               # Octave/MATLAB autosave files
.jitcache           # Octave's JIT cache